# Copia este archivo a .env y completa los valores
# cp .env.example .env

# ── Auth — genera con: openssl rand -hex 32 ────────────────────
GATEWAY_AUTH_SESSION_SECRET=
GATEWAY_AUTH_ENCRYPTION_KEY=

# ── Google OAuth — https://console.cloud.google.com/ ──────────
GATEWAY_GOOGLE_CLIENT_ID=
GATEWAY_GOOGLE_CLIENT_SECRET=
GATEWAY_GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ── Cloudflare Turnstile — https://dash.cloudflare.com/ ────────
GATEWAY_TURNSTILE_SECRET_KEY=
GATEWAY_TURNSTILE_SITE_KEY=

# ── SMTP Gmail — https://myaccount.google.com/apppasswords ─────
GATEWAY_SMTP_HOST=smtp.gmail.com
GATEWAY_SMTP_PORT=587
GATEWAY_SMTP_USER=
GATEWAY_SMTP_PASSWORD=
GATEWAY_SMTP_FROM=

# ── App ────────────────────────────────────────────────────────
GATEWAY_APP_URL=http://localhost:8080

# ── Docker Compose ─────────────────────────────────────────────
POSTGRES_USER=switchboard
POSTGRES_PASSWORD=
POSTGRES_DB=switchboard
REDIS_PASSWORD=